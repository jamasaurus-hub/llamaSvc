generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// ========================
/// Content Layer
/// ========================

model User {
  id              String          @id @default(uuid())
  authProvider    String
  authProviderId  String
  email           String
  plan            String?
  createdAt       DateTime        @default(now())
  lastActiveAt    DateTime?
  collections     Collection[]
  learningItems   LearningItem[]
  userLearning    UserLearningItem[]
  gameSessions    GameSession[]

  @@unique([authProvider, authProviderId])
}

model Collection {
  id              String         @id @default(uuid())
  ownerUserId     String
  name            String
  description     String
  isSystemGenerated Boolean      @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  owner           User           @relation(fields: [ownerUserId], references: [id])
  learningItems   LearningItem[]
}

model LearningItem {
  id             String       @id @default(uuid())
  ownerUserId    String
  collectionId   String
  termText       String
  definitionText String
  sourceContext  String?
  sourceUrl      String?
  canonicalEntryId String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  owner          User         @relation(fields: [ownerUserId], references: [id])
  collection     Collection?  @relation(fields: [collectionId], references: [id])
  canonicalEntry CanonicalEntry @relation(fields: [canonicalEntryId], references: [id])
  userLearning   UserLearningItem[]
}

/// ========================
/// System Intelligence Layer
/// ========================

model CanonicalEntry {
  id                 String                @id @default(uuid())
  normalisedTerm     String
  normalisedDefinition String
  language           String
  createdAt          DateTime              @default(now())

  learningItems      LearningItem[]
  canonicalEntryTags CanonicalEntryTag[]

  @@unique([normalisedTerm, normalisedDefinition, language])
}

model Tag {
  id                  String                @id @default(uuid())
  name                String
  category            String
  createdAt           DateTime              @default(now())
  canonicalEntryTags  CanonicalEntryTag[]
}

model CanonicalEntryTag {
  canonicalEntryId String
  tagId            String

  canonicalEntry   CanonicalEntry @relation(fields: [canonicalEntryId], references: [id])
  tag              Tag            @relation(fields: [tagId], references: [id])

  @@id([canonicalEntryId, tagId])
}

/// ========================
/// User Learning State Layer
/// ========================

model UserLearningItem {
  userId        String
  learningItemId String
  timesSeen     Int      @default(0)
  timesCorrect  Int      @default(0)
  timesIncorrect Int     @default(0)
  isFlagged     Boolean  @default(false)
  lastSeenAt    DateTime?
  nextReviewAt  DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User        @relation(fields: [userId], references: [id])
  learningItem  LearningItem @relation(fields: [learningItemId], references: [id])

  @@id([userId, learningItemId])
}

/// ========================
/// Analytics Layer
/// ========================

model GameSession {
  id        String   @id @default(uuid())
  userId    String
  gameId    String
  startedAt DateTime
  endedAt   DateTime?

  user      User     @relation(fields: [userId], references: [id])
}